# ── BetterSnap local test harness — copy to .env and fill in ──
# .env is gitignored (see .gitignore). NEVER commit real secrets.
#
# Get the storage connection string / account key from the Azure portal
# (Storage account "bettersnapaistorage" -> Access keys) or from Key Vault.
# Get the DB password from Key Vault secret "Db-Password".

# ── Harness 1 (local_test.py) — which job to replay ──────────
# Test-isolation convention: two devs share one DB/storage, so namespace
# everything with test-<yourname>-<n> (job ids) and test-<yourname> (user ids).
JOB_ID=test-alice-1
USER_ID=test-alice

# ── Azure SQL (shared/db.py) ─────────────────────────────────
# Only the password is needed; server/db/uid are hardcoded in shared/db.py.
DB_PASSWORD=

# ── Azure Blob + Queue (shared/blob.py, shared/queue_client.py) ─
STORAGE_CONNECTION_STRING=
# Needed only for SAS result URLs (function_app.py result-url endpoint):
STORAGE_ACCOUNT_KEY=

# ── Auth (shared/auth.py) ────────────────────────────────────
# Signature is NOT verified locally (verify_signature=False), so any value
# works for minting a test JWT. Set it only if you also want func start to
# avoid the Key Vault call for "supabase-jwt-secret".
SUPABASE_JWT_SECRET=local-dev-not-verified

# ── Harness 2 (upload simulation) ────────────────────────────
API_BASE_URL=http://localhost:7071/api
